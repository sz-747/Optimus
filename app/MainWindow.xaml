<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Cmux.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:splits="using:Cmux.Splits">

    <!-- Phase 2: a split-tree workspace of tabbed terminal panes fills the window. -->
    <Grid x:Name="Root" Background="#0C0C0C">
        <splits:WorkspaceView x:Name="Workspace" />
    </Grid>
</Window>
