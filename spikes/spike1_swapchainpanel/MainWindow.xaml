<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Spike1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- The SwapChainPanel is the wgpu composition target (plan §5.1). The overlay reports
         create/resize/DPI state so the GATE can be confirmed visually without a debugger. -->
    <Grid>
        <SwapChainPanel x:Name="Panel" />
        <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                Background="#A0000000" Padding="10,6" CornerRadius="0,0,8,0">
            <TextBlock x:Name="Status"
                       Foreground="White"
                       FontFamily="Consolas"
                       FontSize="13"
                       Text="initializing…" />
        </Border>
    </Grid>
</Window>
